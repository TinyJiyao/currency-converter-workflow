// Main
function run(argv) {
  // 需求1：从用户配置读取默认基准货币和默认目标货币
  const baseCurrency = envVarOrDefault("base_currency", "USD").toUpperCase()
  const defaultTargets = envVarOrDefault("default_targets", "").toUpperCase()
    .split(",").map(s => s.trim()).filter(s => s.length > 0)

  const ratesFile = `${envVar("alfred_workflow_cache")}/rates${baseCurrency}.json`
  const currencies = fetchRates(baseCurrency, ratesFile)

  const formatter = $.NSNumberFormatter.alloc.init
  formatter.numberStyle = $.NSNumberFormatterDecimalStyle
  formatter.minmumFractionDigits = 0
  formatter.maximumFractionDigits = 2
  formatter.hasThousandSeparators = envVar("thousands_group") === "1"

  // 需求2：允许货币符号出现在数字前面（如 $42、¥100）
  // 先尝试提取开头的货币符号
  const rawInput = argv[0]

  // 匹配开头符号（非数字、非字母、非空格的字符，或已知多字符符号前缀）
  // 策略：先检查开头是否有符号映射，再按原逻辑处理
  let prefixSymbol = ""
  let strippedInput = rawInput

  // 尝试从输入开头提取符号（贪心：先试2字符，再试1字符）
  const inputForSymbol = rawInput.trimStart()
  for (const sym of Object.keys(SYMBOL_MAP).sort((a,b) => b.length - a.length)) {
    if (inputForSymbol.toLowerCase().startsWith(sym)) {
      // 确认符号后紧跟数字或空格+数字
      const after = inputForSymbol.slice(sym.length).trimStart()
      if (/^\d/.test(after)) {
        prefixSymbol = sym
        strippedInput = after
        break
      }
    }
  }

  const interpretedInput = strippedInput.replace(/ (to|in|as) /i, " ").toLowerCase()
  const rawNumber = interpretedInput.replace(/^(\d*(\.\d+)?)\D*/, "$1")
  const rawOperation = interpretedInput.substring(rawNumber.length).trim()
  const splitOperation = rawOperation.split(" ")
  const numberValue = parseFloat(rawNumber)

  // 如果开头有符号，则 originCurrency 直接由符号决定（忽略后面可能残留的货币词）
  const originCurrency = prefixSymbol
    ? prefixSymbol.toLowerCase()
    : (splitOperation[0] || "")
  const targetCurrency = prefixSymbol
    ? (splitOperation[0] || "")
    : (splitOperation[1] || "")

  // Abort if invalid number
  if (Number.isNaN(numberValue)) return JSON.stringify({ items: [{
    title: "Input a Value and a Currency",
    subtitle: "Example: 42 EUR  or  $42  or  ¥100",
    valid: false
  }]})

  // When no starting currencies specified, show all (prioritise default targets if set)
  if (originCurrency.length === 0) {
    const allCodes = Object.keys(currencies)
    const orderedCodes = defaultTargets.length > 0
      ? [...defaultTargets.filter(c => currencies[c]), ...allCodes.filter(c => !defaultTargets.includes(c))]
      : allCodes

    return JSON.stringify({ items: orderedCodes.map(currencyCode => ({
      uid: currencyCode,
      title: `${numberValue} ${currencyCode}`,
      subtitle: `${currencies[currencyCode].country} ${currencies[currencyCode].coin}`,
      autocomplete: `${numberValue} ${currencyCode} to `,
      valid: false,
      icon: { path: `images/flags/${currencyCode}.png` }
    }))})
  }

  // Get matches when starting currency specified
  const startCurrencies = matchCurrencies(originCurrency, currencies)
  const startCurrenciesCodes = Object.keys(startCurrencies)
  const startMatchCount = startCurrenciesCodes.length

  // When no starting currencies match, ask for corrections
  if (startMatchCount === 0) return JSON.stringify({ items: [{
    title: "Input a Valid Currency",
    subtitle: "Examples: EUR, GBP, USD, $, ¥, €",
    valid: false
  }]})

  // When multiple starting currencies match, narrow with autocomplete
  if (startMatchCount > 1) return JSON.stringify({ items: startCurrenciesCodes.map(currencyCode => ({
    uid: currencyCode,
    title: `${numberValue} ${currencyCode}`,
    subtitle: `${currencies[currencyCode].country} ${currencies[currencyCode].coin}`,
    autocomplete: `${numberValue} ${currencyCode} to `,
    valid: false,
    icon: { path: `images/flags/${currencyCode}.png` }
  }))})

  // When only one currency matches, convert
  const startCurrencyCode = startCurrenciesCodes[0]

  // 需求1：若没有指定目标货币，且设置了默认目标，则只展示默认目标
  const endCurrencies = targetCurrency.length === 0 && defaultTargets.length > 0
    ? Object.fromEntries(defaultTargets.filter(c => currencies[c]).map(c => [c, currencies[c]]))
    : matchCurrencies(targetCurrency, currencies)

  return JSON.stringify({ items: Object.keys(endCurrencies).flatMap(currencyCode => {
    if (currencyCode === startCurrencyCode) return []
    const convertedValue = currencies[currencyCode].rate / startCurrencies[startCurrencyCode].rate * numberValue
    const formattedValue = formatter.stringFromNumber(convertedValue).js

    return {
      uid: currencyCode,
      title: `${formattedValue} ${currencyCode}`,
      subtitle: `${startCurrencies[startCurrencyCode].country} ${startCurrencies[startCurrencyCode].coin} → ${currencies[currencyCode].country} ${currencies[currencyCode].coin}`,
      arg: formattedValue,
      autocomplete: `${numberValue} ${startCurrencyCode} to ${currencyCode}`,
      icon: { path: `images/flags/${currencyCode}.png` }
    }
  })})
}
