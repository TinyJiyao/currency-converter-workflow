#!/usr/bin/osascript -l JavaScript

// Helpers
function envVar(varName) {
  return $.NSProcessInfo
    .processInfo
    .environment
    .objectForKey(varName).js
}

function envVarOrDefault(varName, defaultValue) {
  const val = $.NSProcessInfo
    .processInfo
    .environment
    .objectForKey(varName).js
  return (val && val.trim().length > 0) ? val.trim() : defaultValue
}

function findMissing(arrayA, arrayB) {
  return [...new Set(arrayA.filter(itemA => !arrayB.includes(itemA)))]
}

// 货币符号 → 货币代码映射
// 注意：部分符号（如 $）对应多种货币，这里映射到最常用的一种
const SYMBOL_MAP = {
  "$":  "USD",
  "us$": "USD",
  "u$": "USD",
  "€":  "EUR",
  "£":  "GBP",
  "¥":  "CNY",   // 默认映射人民币；日元请用 円、jp¥ 或 jpy
